{
  "$schema": "https://schemas.wp.org/wp/6.5/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "450px",
      "wideSize": "760px"
    },
    "typography": {
      "fontSizes": [
        {
          "slug":"small",
          "size": "10px",
          "name": "Small"
        },
        {
          "slug":"medium",
          "size": "13px",
          "name": "Medium"
        }
      ],
      "customFontSize": false,
      "fontFamilies": [
        {
          "slug": "arial",
          "name": "",
          "fontFamily": "'Lucida Grande', Verdana, Arial, Sans-Serif"
        }
      ]
    },
    "color": {
      "custom": true,
      "defaultPalette": false,
      "text": true,
      "background": true,
      "link": true,
      "palette": [
        {
          "slug": "thunay-black",
          "color": "#333333",
          "name": "Black"
        },
        {
          "slug": "thunay-grey",
          "color": "#777777",
          "name": "Grey"
        },
        {
          "slug": "thunay-blue",
          "color": "#06c",
          "name": "Blue"
        }
      ],
      "defaultGradients": false,
      "customGradient": false,
      "gradients": [
        {
          "slug": "thunay-header-gradient",
          "gradient": "linear-gradient(180deg, rgba(107,172,227,1) 0%, rgba(66,129,184,1) 100%)",
          "name": "My awesome new header gradient!"
        },
        {
          "slug": "thunay-footer-gradient",
          "gradient": "linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(232,232,232,1) 100%)",
          "name": "gradient-2"
        }
      ],
      "defaultDuotone": false,
      "customDuotone": false,
      "duotone": [
        {
          "slug": "thunay-duotone-1",
          "colors": ["#fff", "#000"],
          "name": "My awesome new header gradient!"
        }
      ]
    },
    "blocks": {
      "core/post-date": {
        "color": {
          "background": false
        },
        "typography": {
          "fontSizes": []
        }
      },
      "core/column": {
        "color": {
          "defaultGradients": false,
          "customGradient": false,
          "gradients": []
        }
      },
      "core/cover": {
        "color": {
          "duotone": []
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "#d5d6d7",
      "text": "#333"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "'Trebuchet MS', 'Lucida Grande', Verdana, Arial, Sans-Serif",
          "fontWeight": "600",
          "lineHeight": "1.2"
        }
      },
      "link": {
        ":hover": {
          "color": {
            "text": "#147"
          },
          "typography": {
            "textDecoration": "underline"
          }
        },
        "color": {
          "text": "#06c"
        },
        "typography": {
          "textDecoration": "none"
        }
      },
      "button": {
        "border": {
          "radius": "8px"
        }
      }
    },
    "typography": {
      "fontFamily": "'Lucida Grande', Verdana, Arial, Sans-Serif",
      "fontSize": "13px",
      "fontStyle": "normal",
      "fontWeight": "400",
      "lineHeight": "1.55"
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    }
  ]
}
